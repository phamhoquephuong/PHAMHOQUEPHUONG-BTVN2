      "source": [
        "import numpy as np\n",
        "import skfuzzy as fuzz\n",
        "from skfuzzy import control as ctrl\n",
        "import gradio as gr\n",
        "from geopy.geocoders import Nominatim\n",
        "from geopy.distance import geodesic\n",
        "import folium\n",
        "import requests\n",
        "geolocator = Nominatim(user_agent=\"tripal_v3_final\")\n",
        "\n",
        "def get_route(start_coords, end_coords):\n",
        "    url = f\"http://router.project-osrm.org/route/v1/driving/{start_coords[1]},{start_coords[0]};{end_coords[1]},{end_coords[0]}?overview=full&geometries=geojson\"\n",
        "    try:\n",
        "        r = requests.get(url, timeout=5)\n",
        "        res = r.json()\n",
        "        if res['code'] == 'Ok':\n",
        "            line = res['routes'][0]['geometry']['coordinates']\n",
        "            route_coords = [(coord[1], coord[0]) for coord in line]\n",
        "            actual_dist = res['routes'][0]['distance'] / 1000\n",
        "            return route_coords, actual_dist\n",
        "    except:\n",
        "        pass\n",
        "    return [start_coords, end_coords], geodesic(start_coords, end_coords).km\n",
        "\n",
        "def get_coords(address):\n",
        "    if not address or len(address.strip()) < 2: return None\n",
        "    search_queries = [f\"{address}, Ho Chi Minh City, Vietnam\", f\"{address}, Vietnam\", address]\n",
        "    for query in search_queries:\n",
        "        try:\n",
        "            location = geolocator.geocode(query, timeout=10)\n",
        "            if location: return (location.latitude, location.longitude)\n",
        "        except: continue\n",
        "    return None\n",
        "\n",
        "fuel = ctrl.Antecedent(np.arange(0, 11, 1), 'fuel')\n",
        "salary = ctrl.Antecedent(np.arange(0, 11, 1), 'salary')\n",
        "weather = ctrl.Antecedent(np.arange(0, 11, 1), 'weather')\n",
        "demand = ctrl.Antecedent(np.arange(0, 11, 1), 'demand')\n",
        "rush = ctrl.Antecedent(np.arange(0, 11, 1), 'rush')\n",
        "vehicle = ctrl.Antecedent(np.arange(0, 3, 1), 'vehicle')\n",
        "fare = ctrl.Consequent(np.arange(0, 101, 1), 'fare')\n",
        "\n",
        "for var in [fuel, salary, weather, demand, rush]:\n",
        "    var['low'] = fuzz.trimf(var.universe, [0, 0, 5])\n",
        "    var['medium'] = fuzz.trimf(var.universe, [0, 5, 10])\n",
        "    var['high'] = fuzz.trimf(var.universe, [5, 10, 10])\n",
        "\n",
        "vehicle['bike'] = fuzz.trimf(vehicle.universe, [0, 0, 1])\n",
        "vehicle['car4'] = fuzz.trimf(vehicle.universe, [0, 1, 2])\n",
        "vehicle['car7'] = fuzz.trimf(vehicle.universe, [1, 2, 2])\n",
        "\n",
        "fare['low'] = fuzz.trimf(fare.universe, [0, 25, 50])\n",
        "fare['medium'] = fuzz.trimf(fare.universe, [30, 60, 90])\n",
        "fare['high'] = fuzz.trimf(fare.universe, [70, 100, 100])\n",
        "\n",
        "rules = [\n",
        "    ctrl.Rule(vehicle['bike'], fare['low']),\n",
        "    ctrl.Rule(vehicle['car4'], fare['medium']),\n",
        "    ctrl.Rule(vehicle['car7'], fare['high']),\n",
        "    ctrl.Rule(demand['high'] | rush['high'], fare['high']),\n",
        "    ctrl.Rule(weather['low'] & demand['low'], fare['low'])\n",
        "]\n",
        "\n",
        "fare_ctrl = ctrl.ControlSystem(rules)\n",
        "fare_sim = ctrl.ControlSystemSimulation(fare_ctrl)\n",
        "\n",
        "def calc_price_logic(distance, v_name, current_points, use_pts, tip_val):\n",
        "    v_map = {\"Xe máy\": 0, \"Ô tô 4 chỗ\": 1, \"Ô tô 7 chỗ\": 2}\n",
        "    v_idx = v_map.get(v_name, 0)\n",
        "\n",
        "    try:\n",
        "        fare_sim.input['fuel'] = 6\n",
        "        fare_sim.input['salary'] = 6\n",
        "        fare_sim.input['weather'] = 5\n",
        "        fare_sim.input['demand'] = 7\n",
        "        fare_sim.input['rush'] = 6\n",
        "        fare_sim.input['vehicle'] = v_idx\n",
        "        fare_sim.compute()\n",
        "\n",
        "        multiplier = 1000 if v_name == \"Xe máy\" else 2500\n",
        "        if v_name == \"Ô tô 7 chỗ\": multiplier = 3500\n",
        "\n",
        "        raw_total = int(fare_sim.output['fare'] * distance * multiplier)\n",
        "\n",
        "\n",
        "        discount = 0\n",
        "        if use_pts and current_points > 0:\n",
        "            discount = current_points * 1000\n",
        "\n",
        "        return max(2000, raw_total - discount + tip_val), raw_total\n",
        "    except:\n",
        "        base = {\"Xe máy\": 5000, \"Ô tô 4 chỗ\": 15000, \"Ô tô 7 chỗ\": 25000}\n",
        "        raw_total = int(base[v_name] * distance)\n",
        "        discount = (current_points * 1000) if (use_pts and current_points > 0) else 0\n",
        "        return max(2000, raw_total - discount + tip_val), raw_total\n",
        "\n",
        "\n",
        "def on_search_or_update(p_addr, d_addr, v_selected, user_pts, use_pts, tip_opt):\n",
        "    if not p_addr or not d_addr:\n",
        "        return \"Lỗi\", \"Nhập địa chỉ đón & đến\", \"\", 0\n",
        "\n",
        "    p_c = get_coords(p_addr)\n",
        "    d_c = get_coords(d_addr)\n",
        "    if not p_c or not d_c:\n",
        "        return \"Lỗi\", \"Không tìm thấy địa chỉ.\", \"\", 0\n",
        "\n",
        "    route_points, dist = get_route(p_c, d_c)\n",
        "    dist = round(dist, 2)\n",
        "\n",
        "    tip_map = {\"Không\": 0, \"5.000 VNĐ\": 5000, \"10.000 VNĐ\": 10000, \"15.000 VNĐ\": 15000}\n",
        "    tip = tip_map.get(tip_opt, 0)\n",
        "\n",
        "    vehicles = [\"Xe máy\", \"Ô tô 4 chỗ\", \"Ô tô 7 chỗ\"]\n",
        "    ordered_vehicles = [v_selected] + [v for v in vehicles if v != v_selected]\n",
        "    price_lines = []\n",
        "\n",
        "    current_fare_for_points = 0\n",
        "\n",
        "    for i, v_name in enumerate(ordered_vehicles):\n",
        "        p, raw_fare = calc_price_logic(dist, v_name, user_pts, use_pts, tip)\n",
        "        if i == 0:\n",
        "            current_fare_for_points = raw_fare\n",
        "            status_text = \" (Đang chọn)\"\n",
        "            if use_pts and user_pts > 0:\n",
        "                status_text += f\" - Đã trừ {user_pts * 1000:,d} VNĐ\"\n",
        "            if tip > 0: status_text += f\" (+ {tip:,d} Tip)\"\n",
        "            price_lines.append(f\"⭐ {v_name.upper()}: {p:,d} VNĐ{status_text}\")\n",
        "        else:\n",
        "            price_lines.append(f\"• {v_name}: {p:,d} VNĐ\")\n",
        "\n",
        "    m = folium.Map(location=p_c, zoom_start=14)\n",
        "    folium.Marker(p_c, popup=\"Điểm đón\").add_to(m)\n",
        "    folium.Marker(d_c, popup=\"Điểm đến\").add_to(m)\n",
        "    folium.PolyLine(route_points, color=\"#5c67f2\", weight=6, opacity=0.8).add_to(m)\n",
        "\n",
        "    full_price_str = f\"Khoảng cách: {dist} km\\n\" + \"\\n\".join(price_lines)\n",
        "    return f\"{dist} km\", full_price_str, m._repr_html_(), current_fare_for_points\n",
        "\n",
        "def on_book(v_name, dist_str, current_pts, use_pts, raw_fare):\n",
        "    if not dist_str or \"Lỗi\" in dist_str:\n",
        "        return \"Vui lòng tìm chuyến trước!\", current_pts\n",
        "\n",
        "    remaining_pts = 0 if use_pts else current_pts\n",
        "    earned_pts = (raw_fare // 10000) * 5\n",
        "    new_pts = remaining_pts + earned_pts\n",
        "\n",
        "    msg = f\"✅ ĐẶT {v_name.upper()} THÀNH CÔNG!\\n\"\n",
        "    if use_pts and current_pts > 0:\n",
        "        msg += f\"👉 Đã dùng {current_pts} xu để giảm giá.\\n\"\n",
        "    msg += f\"🎁 Bạn vừa tích thêm {earned_pts} xu từ chuyến đi này!\"\n",
        "\n",
        "    return f\"<div style='color: white; background: #312e81; padding: 15px; border-radius: 10px; border: 2px solid #5c67f2; text-align: center;'>{msg}</div>\", new_pts\n",
        "\n",
        "custom_css = \"\"\"\n",
        ".gradio-container { background-color: #1a1c2c !important; color: #e2e8f0 !important; }\n",
        "label span { background-color: #5c67f2 !important; color: white !important; font-weight: bold !important; border-radius: 5px !important; padding: 2px 8px !important; }\n",
        "input, textarea, .secondary { background-color: #2d314d !important; color: white !important; border: 1px solid #434767 !important; }\n",
        "button.primary { background: linear-gradient(135deg, #5c67f2, #4338ca) !important; color: white !important; }\n",
        "\"\"\"\n",
        "\n",
        "with gr.Blocks(theme=gr.themes.Default(), css=custom_css) as app:\n",
        "    gr.HTML(\"<div style='text-align:center; padding:15px;'><h1 style='color:#818cf8; font-size: 3em; letter-spacing: 5px;'>TRIPAL</h1></div>\")\n",
        "\n",
        "    raw_fare_hidden = gr.Number(visible=False, value=0)\n",
        "\n",
        "    with gr.Row():\n",
        "        with gr.Column(scale=1):\n",
        "\n",
        "            pts_display = gr.Number(label=\"🪙 Xu hiện có\", value=0, interactive=False)\n",
        "            with gr.Group():\n",
        "                start = gr.Textbox(label=\"Điểm đón\", placeholder=\"Địa chỉ đón...\")\n",
        "                end = gr.Textbox(label=\"Điểm đến\", placeholder=\"Địa chỉ đến...\")\n",
        "                search_btn = gr.Button(\"🔍 TÌM CHUYẾN\", variant=\"primary\")\n",
        "            v_select = gr.Dropdown([\"Xe máy\", \"Ô tô 4 chỗ\", \"Ô tô 7 chỗ\"], label=\"Chọn phương tiện\", value=\"Xe máy\")\n",
        "            with gr.Group():\n",
        "                use_pts_check = gr.Checkbox(label=\"Dùng toàn bộ xu để giảm giá\", value=False)\n",
        "                tip_options = gr.Radio([\"Không\", \"5.000 VNĐ\", \"10.000 VNĐ\", \"15.000 VNĐ\"], label=\"Tips cho tài xế\", value=\"Không\")\n",
        "            book_btn = gr.Button(\"🚖 ĐẶT XE NGAY\")\n",
        "            status = gr.HTML(\"\")\n",
        "        with gr.Column(scale=2):\n",
        "            with gr.Row():\n",
        "                dist_out = gr.Textbox(label=\"Khoảng cách\", interactive=False)\n",
        "                prices_out = gr.Textbox(label=\"Bảng giá (Đã trừ xu & cộng Tip)\", lines=5, interactive=False)\n",
        "            map_out = gr.HTML()\n",
        "\n",
        "    live_inputs = [start, end, v_select, pts_display, use_pts_check, tip_options]\n",
        "\n",
        "    search_btn.click(on_search_or_update, live_inputs, [dist_out, prices_out, map_out, raw_fare_hidden])\n",
        "    v_select.change(on_search_or_update, live_inputs, [dist_out, prices_out, map_out, raw_fare_hidden])\n",
        "    use_pts_check.change(on_search_or_update, live_inputs, [dist_out, prices_out, map_out, raw_fare_hidden])\n",
        "    tip_options.change(on_search_or_update, live_inputs, [dist_out, prices_out, map_out, raw_fare_hidden])\n",
        "\n",
        "    book_btn.click(on_book, [v_select, dist_out, pts_display, use_pts_check, raw_fare_hidden], [status, pts_display])\n",
        "\n",
        "app.launch()"
      ],
